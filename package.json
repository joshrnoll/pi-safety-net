{
  "name": "pi-safety-net",
  "version": "0.1.0",
  "description": "Pi extension that intercepts dangerous shell commands and requires user confirmation before execution",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "safety",
    "extension",
    "security"
  ],
  "scripts": {
    "test": "node --test --import tsx tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "dependencies": {
    "shell-quote": "^1.8.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/shell-quote": "^1.7.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
